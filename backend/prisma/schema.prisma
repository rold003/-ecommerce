generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================================================
// ENUMS
// =========================================================

enum Rol {
  CLIENTE
  ADMIN
}

enum EstadoProducto {
  ACTIVO
  INACTIVO
}

enum EstadoPedido {
  PENDIENTE
  PAGADO
  ENVIADO
  ENTREGADO
  CANCELADO
}

enum MetodoPago {
  TARJETA
  PAYPAL
  TRANSFERENCIA
  CONTRA_ENTREGA
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  FALLIDO
  REEMBOLSADO
}

enum TipoCupon {
  PORCENTAJE
  MONTO_FIJO
}

// =========================================================
// USUARIOS Y AUTENTICACION
// =========================================================

model Usuario {
  id           String  @id @default(uuid())
  nombre       String
  apellido     String
  email        String  @unique
  passwordHash String
  telefono     String?
  avatarUrl    String?
  rol          Rol     @default(CLIENTE)
  activo       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  direcciones   Direccion[]
  pedidos       Pedido[]
  favoritos     Favorito[]
  resenas       Resena[]
  carrito              Carrito?
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]

  @@index([rol])
  @@map("usuarios")
}

model RefreshToken {
  id        String   @id @default(uuid())
  usuarioId String
  tokenHash String   @unique
  expiresAt DateTime
  revocado  Boolean  @default(false)
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  usuarioId String
  tokenHash String   @unique
  expiresAt DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("password_reset_tokens")
}

model Direccion {
  id             String  @id @default(uuid())
  usuarioId      String
  etiqueta       String
  destinatario   String
  telefono       String
  calle          String
  numero         String?
  ciudad         String
  provincia      String
  codigoPostal   String
  pais           String  @default("Ecuador")
  referencia     String?
  predeterminada Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuario Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pedidos Pedido[]

  @@index([usuarioId])
  @@map("direcciones")
}

// =========================================================
// CATALOGO
// =========================================================

model Categoria {
  id          String  @id @default(uuid())
  nombre      String
  slug        String  @unique
  descripcion String?
  imagenUrl   String?
  activa      Boolean @default(true)

  categoriaPadreId String?
  categoriaPadre   Categoria?  @relation("SubCategorias", fields: [categoriaPadreId], references: [id], onDelete: SetNull)
  subcategorias    Categoria[] @relation("SubCategorias")

  productos Producto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoriaPadreId])
  @@map("categorias")
}

model Marca {
  id      String  @id @default(uuid())
  nombre  String
  slug    String  @unique
  logoUrl String?

  productos Producto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marcas")
}

model Producto {
  id             String         @id @default(uuid())
  nombre         String
  slug           String         @unique
  descripcion    String
  precio         Decimal        @db.Decimal(10, 2)
  precioAnterior Decimal?       @db.Decimal(10, 2)
  stock          Int            @default(0)
  sku            String         @unique
  peso           Decimal?       @db.Decimal(10, 3)
  color          String?
  talla          String?
  estado         EstadoProducto @default(ACTIVO)
  destacado      Boolean        @default(false)
  valoracionProm Decimal        @default(0) @db.Decimal(2, 1)
  totalResenas   Int            @default(0)
  vendidos       Int            @default(0)

  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Restrict)

  marcaId String
  marca   Marca  @relation(fields: [marcaId], references: [id], onDelete: Restrict)

  imagenes     Imagen[]
  resenas      Resena[]
  favoritos    Favorito[]
  itemsCarrito ItemCarrito[]
  itemsPedido  DetallePedido[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoriaId])
  @@index([marcaId])
  @@index([estado])
  @@index([precio])
  @@index([destacado])
  @@map("productos")
}

model Imagen {
  id          String  @id @default(uuid())
  productoId  String
  url         String
  publicId    String?
  altText     String?
  orden       Int     @default(0)
  esPrincipal Boolean @default(false)

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productoId])
  @@map("imagenes")
}

model Resena {
  id           String  @id @default(uuid())
  usuarioId    String
  productoId   String
  calificacion Int
  comentario   String?
  aprobada     Boolean @default(true)

  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioId, productoId])
  @@index([productoId])
  @@map("resenas")
}

model Favorito {
  id         String @id @default(uuid())
  usuarioId  String
  productoId String

  usuario  Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([usuarioId, productoId])
  @@index([usuarioId])
  @@map("favoritos")
}

// =========================================================
// CARRITO
// =========================================================

model Carrito {
  id        String  @id @default(uuid())
  usuarioId String  @unique
  cuponId   String?

  usuario Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cupon   Cupon?        @relation(fields: [cuponId], references: [id], onDelete: SetNull)
  items   ItemCarrito[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carritos")
}

model ItemCarrito {
  id         String @id @default(uuid())
  carritoId  String
  productoId String
  cantidad   Int    @default(1)

  carrito  Carrito  @relation(fields: [carritoId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([carritoId, productoId])
  @@map("items_carrito")
}

model Cupon {
  id           String    @id @default(uuid())
  codigo       String    @unique
  tipo         TipoCupon
  valor        Decimal   @db.Decimal(10, 2)
  fechaInicio  DateTime
  fechaFin     DateTime
  usoMaximo    Int?
  usosActuales Int       @default(0)
  montoMinimo  Decimal?  @db.Decimal(10, 2)
  activo       Boolean   @default(true)

  carritos Carrito[]
  pedidos  Pedido[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cupones")
}

// =========================================================
// PEDIDOS Y PAGOS
// =========================================================

model Pedido {
  id                String       @id @default(uuid())
  numero            String       @unique
  usuarioId         String
  direccionId       String
  subtotal          Decimal      @db.Decimal(10, 2)
  iva               Decimal      @db.Decimal(10, 2)
  costoEnvio        Decimal      @db.Decimal(10, 2)
  descuento         Decimal      @default(0) @db.Decimal(10, 2)
  total             Decimal      @db.Decimal(10, 2)
  metodoPago        MetodoPago
  estado            EstadoPedido @default(PENDIENTE)
  cuponId           String?
  notas             String?
  numeroSeguimiento String?

  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  direccion Direccion @relation(fields: [direccionId], references: [id], onDelete: Restrict)
  cupon     Cupon?    @relation(fields: [cuponId], references: [id], onDelete: SetNull)

  items DetallePedido[]
  pago  Pago?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([usuarioId])
  @@index([estado])
  @@map("pedidos")
}

model DetallePedido {
  id             String  @id @default(uuid())
  pedidoId       String
  productoId     String
  nombreProducto String
  precioUnitario Decimal @db.Decimal(10, 2)
  cantidad       Int
  subtotal       Decimal @db.Decimal(10, 2)

  pedido   Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@map("detalle_pedidos")
}

model Pago {
  id                String     @id @default(uuid())
  pedidoId          String     @unique
  metodo            MetodoPago
  estado            EstadoPago @default(PENDIENTE)
  monto             Decimal    @db.Decimal(10, 2)
  referenciaExterna String?
  pagadoEn          DateTime?

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pagos")
}
