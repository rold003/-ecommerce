NODE_ENV=test
PORT=4000

# Misma instancia de Postgres del docker-compose, pero base de datos separada
# para no tocar los datos de desarrollo/seed al correr los tests.
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce_test?schema=public

JWT_ACCESS_SECRET=test_access_secret_solo_para_pruebas_1234567890
JWT_REFRESH_SECRET=test_refresh_secret_solo_para_pruebas_1234567890
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:5173

EMAIL_FROM=no-reply@ecommerce.local

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

TAX_RATE=0.15
SHIPPING_FLAT_RATE=5
FREE_SHIPPING_THRESHOLD=50
