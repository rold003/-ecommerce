NODE_ENV=development
PORT=4000

# Base de datos (coincide con docker-compose.yml de la raiz)
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce_db?schema=public

# JWT - generar secretos reales con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=changeme_access_secret_min_16_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_min_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
COOKIE_DOMAIN=localhost

# CORS (origen del frontend, separar por coma si hay varios)
CORS_ORIGIN=http://localhost:5173

# Cloudinary (modulo de productos)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (modulo de notificaciones)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@ecommerce.local

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Reglas de negocio del carrito/checkout
TAX_RATE=0.15
SHIPPING_FLAT_RATE=5
FREE_SHIPPING_THRESHOLD=50
